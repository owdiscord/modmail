{
	"name": "modmailbot",
	"version": "4.1.0",
	"packageManager": "pnpm@11.1.3",
	"description": "",
	"license": "MIT",
	"main": "src/index.js",
	"type": "module",
	"scripts": {
		"test": "tsx --test 'src/**/*.test.ts'",
		"build": "swc ./src -d dist --strip-leading-paths",
		"typecheck": "tsc --noEmit",
		"prestart": "pnpm run build",
		"start": "node dist/index.js",
		"dev": "NODE_ENV=development tsx src/index.ts",
		"web": "tsx --watch src/web-node.ts",
		"watch": "NODE_ENV=development tsx --watch src/index.ts",
		"lint": "biome check ./src",
		"lint:fix": "biome check --write --unsafe ./src",
		"migrate:up": "tsx ./src/migrate.ts up",
		"migrate:new": "tsx ./src/migrate.ts new",
		"migrate:down": "tsx ./src/migrate.ts down"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/owdiscord/modmail"
	},
	"dependencies": {
		"@hono/node-server": "^2.0.2",
		"ajv": "^8.17.1",
		"discord-api-types": "^0.37.101",
		"discord.js": "14.24",
		"dotenv": "^16.4.5",
		"hono": "^4.11.3",
		"humanize-duration": "^3.32.1",
		"ini": "^4.1.3",
		"json5": "^2.2.3",
		"knub-command-manager": "^6.1.0",
		"marked": "^17.0.6",
		"mysql2": "^3.11.3",
		"pino": "^10.3.1",
		"public-ip": "^6.0.2",
		"smol-toml": "^1.6.0",
		"uuid": "13.0.0",
		"yargs-parser": "^21.1.1"
	},
	"devDependencies": {
		"typescript": "^6.0.3",
		"@biomejs/biome": "^2.3.14",
		"@swc/cli": "^0.8.1",
		"@swc/core": "^1.15.33",
		"@types/humanize-duration": "^3.27.4",
		"@types/ini": "^4.1.1",
		"@types/yargs-parser": "^21.0.3",
		"jsdoc-to-markdown": "^8.0.3",
		"json-schema-to-jsdoc": "^1.1.1",
		"tsx": "^4.22.1"
	},
	"engines": {
		"node": ">= 24.15.0"
	}
}
